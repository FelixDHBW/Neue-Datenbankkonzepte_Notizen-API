{
    "name": "backend",
    "version": "1.0.0",
    "description": "Express.js Backend API für Notizen-Verwaltung",
    "main": "dist/index.js",
    "scripts": {
        "prestart": "echo Starting backend...",
        "start": "node --experimental-specifier-resolution=node dist/index.js",
        "predev": "echo Starting backend dev server...",
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "seed": "tsx src/seed.ts",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": [
        "express",
        "mongodb",
        "api",
        "notizen"
    ],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/FelixDHBW/Neue-Datenbankkonzepte_Notizen-API/issues"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "globals": "^15.0.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.2.0",
        "ts-node": "^10.9.2",
        "tsx": "^4.19.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.2.3"
    }
}
