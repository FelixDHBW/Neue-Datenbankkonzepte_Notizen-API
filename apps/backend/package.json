{
    "name": "backend",
    "version": "1.0.0",
    "description": "Express.js Backend API für Notizen-Verwaltung",
    "main": "dist/index.js",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "start": "node --experimental-specifier-resolution=node dist/index.js",
        "dev": "nodemon src/index.ts",
        "build": "tsc",
        "seed": "ts-node src/seed.ts",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": ["express", "mongodb", "api", "notizen"],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/FelixDHBW/Neue-Datenbankkonzepte_Notizen-API/issues"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^29.5.12",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.3.2",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "globals": "^15.0.0",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^9.1.6",
        "nodemon": "^3.1.14",
        "prettier": "^3.2.0",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.2.3"
    }
}
