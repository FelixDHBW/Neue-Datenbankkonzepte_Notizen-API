# Server-Konfiguration
PORT=5000

# MongoDB Verbindung (LOKAL - Standard)
# Stelle sicher, dass MongoDB auf deinem System läuft!
# Windows: services.msc -> MongoDB Server starten
# oder: "net start MongoDB" in Admin-CMD
MONGO_URI=mongodb://localhost:27017/notizen-api

# MongoDB Atlas (Cloud) - nur wenn du keinen lokalen Server hast:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/notizen-api

# JWT Konfiguration
# Mindestens 32 Zeichen für Produktionsumgebungen!
JWT_SECRET=dein-geheimer-schluessel-mindestens-32-zeichen-lang

# Umgebung (development | production)
NODE_ENV=development