{
    "compilerOptions": {
        "target": "esnext",
        "module": "commonjs",
        "moduleResolution": "node",
        "lib": [
            "esnext"
        ],
        "typeRoots": [
            "./node_modules/@types",
            "./src/types"
        ],
        /* Dateilayout - WICHTIG */
        "rootDir": "./src", // Wo dein TS-Code liegt [cite: 41]
        "outDir": "./dist", // Wo der kompilierte JS-Code landet
        /* Interoperabilität */
        "esModuleInterop": true, // Wichtig für Express & Mongoose
        "forceConsistentCasingInFileNames": true,
        /* Strenge Typprüfung */
        "strict": true,
        "noUncheckedIndexedAccess": true,
        /* Verhindert Fehler beim Bauen */
        "skipLibCheck": true,
        "sourceMap": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}